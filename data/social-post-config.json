{
  "mode": "feed_and_stories",
  "stories_enabled": true,
  "posts_per_day": 20,
  "stories_per_day": 20,
  "platforms": ["instagram", "facebook"],
  "instagram_handle": "krown.82",
  "layout": {
    "version": "v4-hero",
    "instagram_story": { "size": "1080x1920", "safe_area_px": 120, "hero_logo_pct": "30-40%" },
    "instagram_feed": { "size": "1080x1350", "safe_area_px": 100, "hero_logo_pct": "30-40%" },
    "facebook_post": { "size": "1080x1350", "safe_area_px": 100, "hero_logo_pct": "30-40%" },
    "facebook_story": { "size": "1080x1350", "safe_area_px": 100, "hero_logo_pct": "30-40%" },
    "rules": ["logo_hero_centered", "png_transparent", "no_links", "no_urls"]
  },
  "schedule": {
    "timezone": "Europe/Rome",
    "start_hour": 7,
    "end_hour": 22,
    "interval_minutes": 30,
    "slots": 20
  },
  "workflows": [
    "instagram-auto-post.yml",
    "facebook-auto-post.yml"
  ],
  "note": "20 post feed + 20 story/giorno da articles.json. Layout hero logo centrato v4."
}